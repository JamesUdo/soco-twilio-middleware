# ========================================
# SOCO PRODUCTION - Twilio Middleware Config
# ========================================
# Copy this file to .env and fill in your values

# Twilio Credentials (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Base44 API
BASE44_APP_ID=6991071af68812a959821948
BASE44_API_URL=https://avlproj.base44.app/api/apps/6991071af68812a959821948
BASE44_API_KEY=your_base44_api_key_here

# Server
PORT=3000
BASE_URL=https://your-deployed-url.com

# Optional: Voicemail transcription language
VOICEMAIL_LANGUAGE=en-US
